{
  "default_task_key": "ppe_person",
  "services": {
    "ppe_person": {
      "service_type": "detector",
      "geometry_source": "detector",
      "model_name": "replace_with_detector_name",
      "model_version": "replace_with_detector_version",
      "endpoint": "http://127.0.0.1:8001/detect",
      "method": "POST",
      "timeout_seconds": 60,
      "request": {
        "image_field": "image_uri",
        "extra_payload": {
          "task": "ppe_person"
        }
      },
      "response": {
        "format": "boxes",
        "bbox_format": "xyxy",
        "boxes_field": "boxes",
        "label_field": "label",
        "bbox_field": "bbox",
        "confidence_field": "score"
      },
      "object_type_map": {
        "person": "person"
      }
    },
    "area_segmentation": {
      "service_type": "segmentation_model",
      "geometry_source": "segmentation_model",
      "model_name": "replace_with_segmenter_name",
      "model_version": "replace_with_segmenter_version",
      "endpoint": "http://127.0.0.1:8002/segment",
      "method": "POST",
      "timeout_seconds": 120,
      "request": {
        "image_field": "image_uri",
        "extra_payload": {
          "task": "ground_area"
        }
      },
      "response": {
        "format": "objects",
        "objects_field": "objects"
      },
      "object_type_map": {
        "ground_area": "ground_area",
        "yellow_black_line": "yellow_black_line"
      }
    },
    "local_command_example": {
      "service_type": "detector",
      "geometry_source": "detector",
      "model_name": "replace_with_local_model_name",
      "model_version": "replace_with_local_model_version",
      "command": [
        "python",
        "C:\\path\\to\\detector_service_cli.py",
        "--image",
        "{image_uri}",
        "--output-json",
        "{output_json}"
      ],
      "timeout_seconds": 120,
      "response": {
        "format": "boxes",
        "boxes_field": "boxes",
        "label_field": "label",
        "bbox_field": "bbox",
        "confidence_field": "score"
      },
      "object_type_map": {
        "person": "person"
      }
    }
  }
}
