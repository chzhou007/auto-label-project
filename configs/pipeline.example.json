  "direct_annotation": {
    "default_task_key": "ppe_person",
    "crop_expand_ratio": 0.05,
    "min_box_confidence": 0.0
  },
  "generation": {
    "vlm_model": "aios-smart-eye-vlm",
    "image_model": "wan2.7-image-pro",
    "grid_layout": "4x4",
    "edit_bbox_expand_ratio": 0.2,
    "crop_expand_ratio": 0.1,
    "workers": 1,
    "skip_existing": true
  },
  "classification": {
    "skip_source_types": [
      "generated"
    ],
    "classifier_type": "vlm",
    "classifier_name": "classification.py",
    "classifier_version": "external",
    "prompt_version": "classification_script_default",
    "api_url_env": "QWEN397B_API_URL",
    "api_key_env": "QWEN397B_API_KEY",
    "model_env": "QWEN397B_MODEL",
    "delay_seconds": 0.5
  },
  "qc_policy": {
    "qc_mode": "sampling",
    "sampling_ratio": 0.08,
    "sampling_method": "random",
    "fail_policy": "batch_rework",
    "qc_batch_id": null
  },
  "export": {
    "export_format": "labelstudio",
    "export_status": "not_exported"
  }
