{
  "pipeline_id": "autolabel_dag_v1",
  "pipeline_version": "0.1.0",
  "paths": {
    "i2i_project": "C:\\Users\\chang\\Documents\\数据标注\\I2I",
    "classification_script": "scripts/classification.py",
    "raw_images_dir": "data/raw/images",
    "raw_videos_dir": "data/raw/videos",
    "image_sequence_dir": "data/staging/image_sequence",
    "metadata_dir": "data/processed/metadata",
    "crop_dir": "data/processed/crops",
    "mask_dir": "data/processed/masks",
    "export_dir": "data/exports"
  },
  "preprocess": {
    "copy_images": true,
    "video_frame_stride": 30,
    "video_max_frames": null,
    "video_decode_mode": "cpu",
    "ffmpeg_path": "ffmpeg",
    "video_gpu_hwaccel": "cuda",
    "video_gpu_fallback_to_cpu": true,
    "video_error_policy": "skip"
  },
  "direct_annotation": {
    "default_task_key": "ppe_person",
    "crop_expand_ratio": 0.05,
    "min_box_confidence": 0.0,
    "min_box_width": 4,
    "min_box_height": 4,
    "min_box_area": 16,
    "max_box_aspect_ratio": 20.0,
    "cleanup_existing_crops": true,
    "batch_size": 1,
    "workers": 1,
    "json_retry_attempts": 3,
    "crop_review": {
      "enabled": false,
      "model_ref": "ppe_person_vlm_labelstudio_detector",
      "target_object_type": "person",
      "reviewer": "vlm_crop_reviewer",
      "prompt_version": "crop_full_person_review_v1",
      "failed_issue_flag": "incomplete_person_crop",
      "record_passed": false,
      "use_response_format": true,
      "response_format_type": "json_object",
      "max_tokens": 600
    }
  },
  "generation": {
    "vlm_model": "aios-smart-eye-vlm",
    "image_model": "wan2.7-image-pro",
    "grid_layout": "4x4",
    "edit_bbox_expand_ratio": 0.2,
    "crop_expand_ratio": 0.1,
    "workers": 1,
    "skip_existing": true
  },
  "classification": {
    "skip_source_types": [
